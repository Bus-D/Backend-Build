<%- include('../partials/header') %>

<main class="section-container">
        <section class="hero">
            <h1>Client Dashboard</h1>
            <h2>Welcome back, <%= user.name %></h2>
        </section>

        <div class="home-intro">
            <h3>Your Project Overview</h3>
            <p class="muted">Track the progress of your active design projects and view recent updates.</p>
        </div>

        <section class="home-grid">
            <% if (projects.length > 0) { %>
                <% projects.forEach(project => { %>
                    <section class="card-item">
                        <h3><%= project.name %></h3>
                        <p>Status: <strong><%= project.status %></strong></p>
                        
                        <% 
                            let rawProgress = Number(project.progress);
                            if (Number.isNaN(rawProgress)) {
                                rawProgress = 0;
                            }
                            const progress = Math.max(0, Math.min(100, rawProgress));
                        %>
                        <div class="progress-container" style="--progress: <%= progress.progress || 0 %>">
                            <div class="progress-fill"></div>
                        </div>
                        <p class="muted">Completion: <%= progress %>%</p>
                        
                        <div class="form-footer">
                            <a href="/projects/<%= project.id %>" class="order-button">View Project details</a>
                        </div>
                    </section>
                <% }) %>
            <% } else { %>
                <div class="card-item" style="grid-column: 1 / -1; padding: 2rem; text-align: center;">
                    <p>No active projects found.</p>
                    <a href="/contact" class="btn">Start a New Project</a>
                </div>
            <% } %>
        </section>
    </main>

<%- include('../partials/footer') %>